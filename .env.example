# ─────────────────────────────────────────────────────────────────────
# Opus X — Variables d'environnement
# Copier en .env.local et renseigner depuis Supabase → Settings → API
# ─────────────────────────────────────────────────────────────────────

# URL du projet Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clé publique (anon). Sûre côté client : la RLS est la barrière.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# URL de l'application (redirections du magic link)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ⚠️ JAMAIS de service_role côté client (spec §3.11 — least privilege).
# Réservée aux Edge Functions / opérations serveur privilégiées.
# SUPABASE_SERVICE_ROLE_KEY=
